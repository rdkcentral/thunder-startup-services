[Unit]
Description=WPEFramework NetworkManager Initialiser
Requires=wpeframework.service mfrmgr.service NetworkManager.service
After=wpeframework.service mfrmgr.service NetworkManager.service
ConditionPathExists=/tmp/wpeframeworkstarted
[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/bin/PluginActivator org.rdk.NetworkManager
