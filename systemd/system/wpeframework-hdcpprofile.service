[Unit]
Description=WPEFramework HdcpProfile Initialiser
Requires=pwrmgr.service wpeframework.service dsmgr.service
After=pwrmgr.service wpeframework.service dsmgr.service
ConditionPathExists=/tmp/wpeframeworkstarted
[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/bin/PluginActivator org.rdk.HdcpProfile
