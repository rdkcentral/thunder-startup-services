[Unit]
Description=WPEFramework XvpClient Initialiser
Requires=wpeframework.service wpeframework-appgateway.service wpeframework-authservice.service wpeframework-privacy.service
After=wpeframework.service wpeframework-appgateway.service wpeframework-authservice.service wpeframework-privacy.service
ConditionPathExists=/tmp/wpeframeworkstarted
ConditionPathExists=/opt/appgatewayenabled

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/bin/PluginActivator org.rdk.XvpClient

