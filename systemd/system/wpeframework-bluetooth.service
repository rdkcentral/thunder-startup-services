[Unit]
Description=WPEFramework Bluetooth Initialiser
Requires=pwrmgr.service wpeframework.service iarmbusd.service btmgr.service
After=pwrmgr.service wpeframework.service iarmbusd.service btmgr.service
ConditionPathExists=/tmp/wpeframeworkstarted
[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/bin/PluginActivator org.rdk.Bluetooth
