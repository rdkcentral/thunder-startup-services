[Unit]
Description=WPEFramework FrontPanel Initialiser
Requires=wpeframework-devicesettings.service wpeframework-powermanager.service dsmgr.service
After=wpeframework-devicesettings.service wpeframework-powermanager.service dsmgr.service
ConditionPathExists=/tmp/wpeframeworkstarted
[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/bin/PluginActivator org.rdk.FrontPanel
