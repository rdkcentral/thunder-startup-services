[Unit]
Description=WPEFramework DisplayInfo Initialiser
Requires=pwrmgr.service wpeframework.service iarmbusd.service dsmgr.service
After=pwrmgr.service wpeframework.service iarmbusd.service dsmgr.service
ConditionPathExists=/tmp/wpeframeworkstarted
[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/bin/PluginActivator DisplayInfo
