[Unit]
Description=WPEFramework FbMetrics Initialiser
Requires=wpeframework.service wpeframework-appgateway.service wpeframework-analytics.service
After=wpeframework.service wpeframework-appgateway.service wpeframework-analytics.service
ConditionPathExists=/tmp/wpeframeworkstarted
ConditionPathExists=/opt/appgatewayenabled

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/bin/PluginActivator org.rdk.FbMetrics

