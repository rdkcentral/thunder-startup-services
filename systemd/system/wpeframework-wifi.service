[Unit]
Description=WPEFramework Wifi Initialiser
Requires=wpeframework.service wpeframework-networkmanager.service
After=wpeframework.service wpeframework-networkmanager.service
ConditionPathExists=/tmp/wpeframeworkstarted
[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/bin/PluginActivator org.rdk.Wifi
