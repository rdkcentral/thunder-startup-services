[Unit]
Description=WPEFramework System Initialiser
Requires=pwrmgr.service wpeframework.service sysmgr.service mfrmgr.service
After=pwrmgr.service wpeframework.service sysmgr.service mfrmgr.service
ConditionPathExists=/tmp/wpeframeworkstarted
[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/bin/PluginActivator org.rdk.System
