[Unit]
Description=WPEFramework DeviceSettings Initialiser
Requires=wpeframework.service iarmbusd.service wpeframework-powermanager.service
After=lighttpd.service iarmbusd.service sysmgr.service wpeframework-powermanager.service wpeframework.service
ConditionPathExists=/tmp/wpeframeworkstarted
[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/bin/PluginActivator org.rdk.DeviceSettings
[Install]
WantedBy=multi-user.target
