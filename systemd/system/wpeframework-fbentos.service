[Unit]
Description=WPEFramework FBEntos plugin
Requires=wpeframework.service wpeframework-appgateway.service wpeframework-authservice.service wpeframework-texttospeech.service
After=wpeframework.service wpeframework-appgateway.service wpeframework-authservice.service wpeframework-texttospeech.service
ConditionPathExists=/tmp/wpeframeworkstarted
ConditionPathExists=/opt/appgatewayenabled

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/bin/PluginActivator org.rdk.FbEntos

