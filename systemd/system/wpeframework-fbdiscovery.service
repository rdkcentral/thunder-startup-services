[Unit]
Description=WPEFramework FbDiscovery Initialiser
Requires=wpeframework.service wpeframework-appgateway.service wpeframework-xvpclient.service
After=wpeframework.service wpeframework-appgateway.service wpeframework-xvpclient.service
ConditionPathExists=/tmp/wpeframeworkstarted
ConditionPathExists=/opt/appgatewayenabled

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/bin/PluginActivator org.rdk.FbDiscovery

