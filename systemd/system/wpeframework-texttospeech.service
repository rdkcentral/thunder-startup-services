[Unit]
Description=WPEFramework TextToSpeech Initialiser
Requires=wpeframework.service wpeframework-system.service
After=wpeframework.service wpeframework-system.service
ConditionPathExists=/tmp/wpeframeworkstarted
[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/bin/PluginActivator org.rdk.TextToSpeech
