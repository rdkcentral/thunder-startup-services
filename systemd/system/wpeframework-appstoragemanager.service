[Unit]
Description=WPEFramework StorageManager Initialiser
Requires= wpeframework.service wpeframework-persistentstore.service wpeframework-telemetrymetrics.service
After= wpeframework.service wpeframework-persistentstore.service wpeframework-telemetrymetrics.service
ConditionPathExists=/opt/ai2managers
ConditionPathExists=/tmp/wpeframeworkstarted

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/bin/PluginActivator org.rdk.AppStorageManager

